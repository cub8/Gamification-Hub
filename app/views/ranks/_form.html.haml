= form_with(model: [@story_group, rank], local: true) do |form|
  - if rank.errors.any?
    %div{style: "color: red"}
      %h4= "#{pluralize(rank.errors.count, "error")} prohibited this rank from being saved:"
      %ul
        - rank.errors.each do |error|
          %li= error.full_message

  %div
    = form.label :name, style: "display: block"
    = form.text_field :name

  %div
    = form.label :description, style: "display: block"
    = form.textarea :description

  %div
    = form.label :icon, style: "display: block"
    = form.file_field :icon, accept: "image/*"

  %div
    = form.submit "Add Rank"
