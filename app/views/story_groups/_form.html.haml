= form_with(model: story_group) do |form|
  - if story_group.errors.any?
    %div{style: "color: red"}
      %h2= "#{pluralize(story_group.errors.count, "error")} prohibited this story_group from being saved:"

      %ul
        - story_group.errors.each do |error|
          %li= error.full_message

  %div
    = form.label :owner_id, style: "display: block"
    = form.number_field :owner_id

  %div
    = form.label :name, style: "display: block"
    = form.text_field :name

  %div
    = form.label :description, style: "display: block"
    = form.textarea :description

  %div
    = form.label :icon, style: "display: block"
    = form.file_field :icon

  %div
    = form.label :currency_name, style: "display: block"
    = form.text_field :currency_name

  %div
    = form.label :currency_icon, style: "display: block"
    = form.file_field :currency_icon

  %div
    = form.submit
