= form_with(model: [@story_group, badge], local: true) do |form|
  - if badge.errors.any?
    %div{style: "color: red"}
      %h4= "#{pluralize(badge.errors.count, "error")} prohibited this badge from being saved:"
      %ul
        - badge.errors.each do |error|
          %li= error.full_message

  %div
    = form.label :name, style: "display: block"
    = form.text_field :name

  %div
    = form.label :description, style: "display: block"
    = form.textarea :description

  %div
    = form.label :icon, style: "display: block"
    = form.file_field :icon, accept: "image/*"

  %div
    = form.submit "Add Badge"